# Gmail (OAuth2 via Google API)
GMAIL_CREDENTIALS_JSON=credentials.json
GMAIL_TOKEN_JSON=token.json
GMAIL_POLL_INTERVAL_SECONDS=60
GMAIL_LABEL=INBOX
GMAIL_QUERY=has:attachment filename:pdf subject:invoice

# Veryfi OCR
VERYFI_CLIENT_ID=
VERYFI_CLIENT_SECRET=
